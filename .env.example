# --- Gemini (already required, unchanged) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Firebase: client-side config (safe to expose — these are public identifiers,
# not secrets; Firestore/Auth security comes from server-side rules/verification,
# not from hiding these values) ---
# Find these in the Firebase Console: Project Settings > General > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Firebase: server-side Admin SDK (this one IS a secret — never commit it) ---
# Firebase Console: Project Settings > Service Accounts > Generate new private key
# Paste the ENTIRE downloaded JSON file as a single line here, OR base64-encode it
# first (recommended, avoids quoting issues with the JSON's newlines):
#   base64 -i service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Stripe (billing — checkout, subscriptions, refunds) ---
# Stripe Dashboard: Developers > API keys
STRIPE_SECRET_KEY=

# Stripe Dashboard: Developers > Webhooks > Add endpoint
#   URL: https://<your-domain>/api/stripe-webhook
#   Events to send: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=

# Stripe Dashboard: Products > Add Product > Add Price (one per plan), then
# paste each price ID (looks like "price_1AbC...") here:
STRIPE_PRICE_DESIGN_PASS=
STRIPE_PRICE_ARTIST_STARTER=
STRIPE_PRICE_STUDIO=

# --- Admin accounts ---
# Comma-separated list of emails that are automatically promoted to the
# "admin" role (unlimited generations + admin panel access) on sign-in.
ADMIN_EMAILS=craigtrickett@gmail.com
